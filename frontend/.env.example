# Frontend local config — drives Next.js public env vars. Copy to
# .env.local for dev or inject into the Docker build as --build-arg
# when building the production image.

# URL the browser uses to reach SenHarness backend.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# WebSocket base URL — /api/v1/ws/... paths stack on top.
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000

# Product naming.
NEXT_PUBLIC_APP_NAME=SenHarness

# Default locale. Users can override from the avatar menu; this just
# sets the initial render.
NEXT_PUBLIC_DEFAULT_LOCALE=zh-CN

# Optional — surface a marketing-friendly build tag in the footer.
# Commonly set from CI to the git SHA or tag.
# NEXT_PUBLIC_BUILD_TAG=

# ─── Observability (all optional) ──────────────────────────────
#
# Sentry — only initialised if the DSN is set; otherwise the frontend
# skips Sentry entirely. `NEXT_PUBLIC_` prefix is required because
# browser code also reads it.
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_APP_ENV=production
#
# OpenTelemetry — traces are forwarded to this OTLP HTTP endpoint. When
# unset, OTel is skipped. The service name surfaces in Jaeger /
# Logfire / Grafana Tempo as the resource attribute.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# OTEL_SERVICE_NAME=senharness-frontend
#
# Web Vitals — the frontend always forwards CLS/FCP/INP/LCP/TTFB to
# backend `POST /api/v1/metrics/web-vitals`, which lands them in the
# Prometheus histogram `senharness_web_vital_value`. No config
# required — it uses `NEXT_PUBLIC_API_BASE_URL` above.
