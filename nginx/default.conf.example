# Example Nginx config for SenHarness when Traefik is not used.
# Serves:  /        -> frontend (Next.js)
#          /api/*   -> backend (FastAPI)
#          /ws/*    -> backend WebSocket (with upgrade)
#          /webhook/* -> backend public webhook

upstream senharness_backend {
  server backend:8000;
}

upstream senharness_frontend {
  server frontend:3000;
}

map $http_upgrade $connection_upgrade {
  default upgrade;
  ''      close;
}

server {
  listen 80;
  server_name _;
  client_max_body_size 50m;

  # ACME challenge passthrough (if using certbot standalone upstream)
  location /.well-known/acme-challenge/ {
    root /var/www/certbot;
  }

  location /api/ {
    proxy_pass         http://senharness_backend;
    proxy_http_version 1.1;
    proxy_set_header   Host              $host;
    proxy_set_header   X-Real-IP         $remote_addr;
    proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header   X-Forwarded-Proto $scheme;
    proxy_set_header   Upgrade           $http_upgrade;
    proxy_set_header   Connection        $connection_upgrade;
    proxy_read_timeout 600s;
  }

  location /webhook/ {
    proxy_pass         http://senharness_backend;
    proxy_http_version 1.1;
    proxy_set_header   Host              $host;
    proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
  }

  location / {
    proxy_pass         http://senharness_frontend;
    proxy_http_version 1.1;
    proxy_set_header   Host              $host;
    proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header   X-Forwarded-Proto $scheme;
  }
}
