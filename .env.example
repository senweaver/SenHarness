# ═══════════════════════════════════════════════════════════════
# SenHarness environment (copy to .env and fill in)
# ═══════════════════════════════════════════════════════════════

# ─── App ──────────────────────────────────────────────────────
APP_NAME=SenHarness
APP_ENV=development                    # development | staging | production
APP_DEBUG=true
APP_TIMEZONE=Asia/Shanghai
APP_DEFAULT_LOCALE=zh-CN
API_PREFIX=/api/v1

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3000
PUBLIC_BASE_URL=http://localhost:8000

# ─── Security / Keyring ───────────────────────────────────────
# On first boot the EnvKeyring will auto-generate this and log a
# WARNING with the value. Copy it back here for persistence.
SENHARNESS_MASTER_KEY=
KEYRING_PROVIDER=env                   # env | file | passphrase | aws_kms | gcp_kms | azure_kv | vault | hsm
KEYRING_FILE_PATH=/etc/senharness/keyring.jwks
# AWS KMS
AWS_KMS_KEY_ID=
AWS_REGION=
# GCP KMS
GCP_KMS_KEY_NAME=
# Azure Key Vault
AZURE_KV_URL=
AZURE_KV_KEY_NAME=
# HashiCorp Vault
VAULT_ADDR=
VAULT_TRANSIT_KEY=

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_SECONDS=1800
JWT_REFRESH_TTL_SECONDS=2592000
JWT_REFRESH_COOKIE_NAME=sh_refresh
JWT_REFRESH_COOKIE_SECURE=false

# ─── CORS ─────────────────────────────────────────────────────
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Database (Postgres + pgvector) ──────────────────────────
DB_HOST=db
DB_PORT=5432
DB_USER=senharness
DB_PASSWORD=senharness
DB_NAME=senharness
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ─── OAuth providers (optional) ──────────────────────────────
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_MICROSOFT_CLIENT_SECRET=
# Where the OAuth callback should redirect the browser after token exchange.
# Defaults to the first CORS_ALLOW_ORIGINS entry when blank.
OAUTH_REDIRECT_BASE=

# ─── SSO (OIDC) ───────────────────────────────────────────────
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# ─── LLM providers (optional defaults; per-workspace overrides in Vault) ──
# Fill any one to enable real inference; leave all empty for the placeholder stream.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
# CN-friendly providers:
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=
GROQ_API_KEY=
# Local Ollama (no key required; uncomment to enable):
# OLLAMA_HOST=http://host.docker.internal:11434
# OLLAMA_MODEL=llama3.1

# ─── Search providers (optional) ──────────────────────────────
TAVILY_API_KEY=
SERPAPI_KEY=
JINA_API_KEY=
EXA_API_KEY=

# ─── Observability ────────────────────────────────────────────
# Pydantic Logfire SaaS (most zero-config option).
LOGFIRE_TOKEN=
# Generic OTLP/HTTP traces endpoint (Tempo / Jaeger / Honeycomb / Grafana Cloud).
# Example: http://tempo:4318/v1/traces
OTEL_EXPORTER_OTLP_ENDPOINT=
# Langfuse (agent traces + costs). Get keys at https://cloud.langfuse.com.
# Self-hosted? Set LANGFUSE_HOST=http://langfuse.internal:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
# Sentry error tracking (optional).
SENTRY_DSN=
# Log format: "text" (dev) or "json" (ship to ELK/Loki).
LOG_FORMAT=text

# ─── Pricing overrides (optional) ────────────────────────────
# JSON map of model → [input_usd_per_mtok, output_usd_per_mtok] used by
# /metrics/usage to turn token counts into real dollars. Defaults live in
# app/core/pricing.py. Example:
# PRICING_OVERRIDES_JSON={"my-local-llama":[0,0],"gpt-4o":[2.0,8.0]}
PRICING_OVERRIDES_JSON=

# ─── Rate limit defaults ──────────────────────────────────────
RATE_LIMIT_DEFAULT_LIMIT=120
RATE_LIMIT_DEFAULT_PERIOD=60

# ─── File storage ─────────────────────────────────────────────
STORAGE_BACKEND=local                  # local | s3 | oss
STORAGE_LOCAL_PATH=/data/storage
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ─── Sandbox (Agent tool execution) ──────────────────────────
# In production we refuse sandbox.kind=local with execute=true because that
# runs arbitrary shell on the SenHarness backend host. Use kind=docker or
# kind=state unless you've reviewed the security tradeoff and explicitly
# accept it by setting this flag to true.
SANDBOX_LOCAL_EXECUTE_PROD=false

# ─── Frontend (injected to Next.js) ──────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000
NEXT_PUBLIC_APP_NAME=SenHarness
NEXT_PUBLIC_DEFAULT_LOCALE=zh-CN
