# ═══════════════════════════════════════════════════════════════
# SenHarness environment (copy to .env and fill in)
#
# Single source of truth — both host runs and docker compose read this
# file. Docker compose's `environment:` block transparently overrides
# DB_HOST / REDIS_HOST / STORAGE_LOCAL_PATH inside containers, so the
# host-friendly defaults below are safe in both modes.
# ═══════════════════════════════════════════════════════════════

# ─── App ──────────────────────────────────────────────────────
APP_NAME=SenHarness
APP_ENV=development                    # development | staging | production
APP_DEBUG=true
APP_TIMEZONE=Asia/Shanghai
APP_DEFAULT_LOCALE=zh-CN
API_PREFIX=/api/v1

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3000
PUBLIC_BASE_URL=http://localhost:8000

# ─── Security / Keyring ───────────────────────────────────────
# On first boot the EnvKeyring will auto-generate this and log a
# WARNING with the value. Copy it back here for persistence.
SENHARNESS_MASTER_KEY=
KEYRING_PROVIDER=env                   # env | file | passphrase | aws_kms | gcp_kms | azure_kv | vault | hsm
KEYRING_FILE_PATH=/etc/senharness/keyring.jwks
# AWS KMS
AWS_KMS_KEY_ID=
AWS_REGION=
# GCP KMS
GCP_KMS_KEY_NAME=
# Azure Key Vault
AZURE_KV_URL=
AZURE_KV_KEY_NAME=
# HashiCorp Vault
VAULT_ADDR=
VAULT_TRANSIT_KEY=

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET_KEY=dev-only-do-not-use-in-production!!
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_SECONDS=1800
JWT_REFRESH_TTL_SECONDS=2592000
JWT_REFRESH_COOKIE_NAME=sh_refresh
JWT_REFRESH_COOKIE_SECURE=false

# ─── CORS ─────────────────────────────────────────────────────
# Comma-separated explicit allow list. To access the backend from a LAN
# IP, append that origin here, e.g. ",http://192.168.1.32:3000".
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Database (Postgres + pgvector) ──────────────────────────
# Host default; docker compose overrides to `db` inside containers.
DB_HOST=localhost
DB_PORT=5432
DB_USER=senharness
DB_PASSWORD=senharness
DB_NAME=senharness
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false
# asyncpg SSL mode: disable | allow | prefer | require | verify-ca | verify-full.
# Host-mode dev on Windows against the dockerised Postgres often needs
# `disable` because Docker Desktop's port-proxy tears the SSL probe socket
# down. Production / cloud DBs should run `require` or stricter.
DB_SSL_MODE=prefer

# ─── Redis ────────────────────────────────────────────────────
# Host default; docker compose overrides to `redis` inside containers.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ─── OAuth providers (optional) ──────────────────────────────
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_MICROSOFT_CLIENT_SECRET=
# Where the OAuth callback should redirect the browser after token exchange.
# Defaults to the first CORS_ALLOW_ORIGINS entry when blank.
OAUTH_REDIRECT_BASE=

# ─── SSO (OIDC) ───────────────────────────────────────────────
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# ─── LLM / search providers ───────────────────────────────────
# Business-level API keys (OpenAI / Anthropic / Google / DeepSeek / Moonshot /
# Tavily / SerpAPI / Brave / Jina / Exa / ...) are NOT configured here.
# Sign in to the SenHarness UI and add them in:
#   • Settings → Providers              (LLM endpoints; one click "Discover"
#                                        pulls /v1/models and lets you
#                                        bulk-enable models.)
#   • Settings → Search providers       (Tavily / SerpAPI / Brave / ...)
# Both stores envelope-encrypt the secret in Vault — keys never appear in
# .env, the database, or the server logs.

# ─── Observability ────────────────────────────────────────────
# Pydantic Logfire SaaS (most zero-config option).
LOGFIRE_TOKEN=
# Generic OTLP/HTTP traces endpoint (Tempo / Jaeger / Honeycomb / Grafana Cloud).
# Example: http://tempo:4318/v1/traces
OTEL_EXPORTER_OTLP_ENDPOINT=
# Langfuse (agent traces + costs). Get keys at https://cloud.langfuse.com.
# Self-hosted? Set LANGFUSE_HOST=http://langfuse.internal:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
# Sentry error tracking (optional).
SENTRY_DSN=
# Log format: "text" (dev) or "json" (ship to ELK/Loki).
LOG_FORMAT=text
# Optional rotating file sink. Blank = stdout-only (12-factor / docker logs).
# Set to keep one rotated file under the storage root, e.g.:
#   LOG_DIR=./.data/storage/logs       (host)
#   LOG_DIR=/data/storage/logs         (containers)
LOG_DIR=
LOG_FILE_MAX_BYTES=10485760
LOG_FILE_BACKUPS=5

# ─── Pricing overrides (optional) ────────────────────────────
# JSON map of model → [input_usd_per_mtok, output_usd_per_mtok] used by
# /metrics/usage to turn token counts into real dollars. Defaults live in
# app/core/pricing.py. Example:
# PRICING_OVERRIDES_JSON={"my-local-llama":[0,0],"gpt-4o":[2.0,8.0]}
PRICING_OVERRIDES_JSON=

# ─── Rate limit defaults ──────────────────────────────────────
RATE_LIMIT_DEFAULT_LIMIT=120
RATE_LIMIT_DEFAULT_PERIOD=60

# ─── File storage ─────────────────────────────────────────────
# Host default; docker compose overrides to /data/storage (volume mount).
STORAGE_BACKEND=local                  # local | s3 | oss
STORAGE_LOCAL_PATH=./.data/storage
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ─── Sandbox (Agent tool execution) ──────────────────────────
# In production we refuse sandbox.kind=local with execute=true because that
# runs arbitrary shell on the SenHarness backend host. Use kind=docker or
# kind=state unless you've reviewed the security tradeoff and explicitly
# accept it by setting this flag to true.
SANDBOX_LOCAL_EXECUTE_PROD=false

# ─── Channel runtime (IM stream mode) ────────────────────────
# When true (default), the FastAPI lifespan runs the IM stream
# supervisor in-process — perfect for single-worker / docker-compose
# dev. In multi-worker production set this to false and start a
# dedicated worker via ``python -m cli.commands channels run``.
CHANNEL_RUNTIME_INPROCESS=true
# Multi-worker advisory Redis lock so only one process per channel
# holds the live IM connection. Single-worker deployments leave off.
CHANNEL_RUNTIME_REDIS_LOCK=false
# Cap on the exponential reconnect backoff (seconds).
CHANNEL_RUNTIME_RECONNECT_BACKOFF_MAX_S=300
# Supervisor reconcile cadence (seconds).
CHANNEL_STREAM_HEARTBEAT_S=30

# ─── Frontend (injected to Next.js) ──────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000
NEXT_PUBLIC_APP_NAME=SenHarness
